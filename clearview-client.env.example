# ClearView client gateway settings for IDEs, SDKs, CLIs, and local tools.
#
# Keep this separate from .env:
# - .env contains real provider keys used by the ClearView server.
# - this file contains client-side settings that point tools at ClearView.

# Preferred universal entry point for OpenAI-compatible tools.
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_API_KEY=clearview-local
OPENAI_MODEL=clearview-auto

# ClearView virtual models:
#   clearview-auto
#   clearview-cheap
#   clearview-mid
#   clearview-frontier

# Compatibility fallbacks for tools hardcoded to Anthropic or Gemini protocols.
ANTHROPIC_BASE_URL=http://localhost:8000
ANTHROPIC_API_KEY=clearview-local
ANTHROPIC_MODEL=clearview-auto

GOOGLE_GEMINI_BASE_URL=http://localhost:8000
GEMINI_API_KEY=clearview-local
GEMINI_MODEL=clearview-auto

