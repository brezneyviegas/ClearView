# Provider keys for the ClearView server (set what you use).
# Do not put IDE client gateway values here; use clearview-client.env.example
# or your IDE's OpenAI-compatible provider settings for that.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Ollama (local, optional)
OLLAMA_BASE_URL=http://localhost:11434
# Runtime health probe: ollama/* models count as available only when the local
# server answers (30s TTL cache), so stage-routed execution falls back to
# cloud tiers instead of erroring when ollama is down.
CLEARVIEW_OLLAMA_PROBE=1

# ClearView config
CLEARVIEW_POLICY_PATH=./policy.yaml
CLEARVIEW_DB_PATH=./clearview.db
CLEARVIEW_BASELINE_MODEL=anthropic/claude-opus-4-7
CLEARVIEW_HOST=0.0.0.0
CLEARVIEW_PORT=8000
