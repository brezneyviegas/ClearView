# ─── ClearView server config ────────────────────────────────────────────────
# Copy to .env and fill in what you have. Everything is optional: with zero
# providers configured, ClearView serves requests from a built-in $0 mock so
# you can explore the dashboard and APIs before wiring anything up.
# Run `python -m app.doctor` to probe your machine and get recommendations.

# Provider API keys (paid REST mode — set what you use)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Subscription CLI adapters — use your logged-in CLI's auth instead of API
# keys. Each adapter spawns the local binary; the CLI carries its own OAuth
# token. Enable any you have installed + logged in:
CLEARVIEW_USE_CLAUDE_CLI=0    # anthropic/* via `claude` (Claude Pro/Max)
CLEARVIEW_USE_CODEX_CLI=0     # openai/*    via `codex`  (ChatGPT Plus/Pro; run `codex login`)
CLEARVIEW_USE_GEMINI_CLI=0    # gemini/*    via `gemini` (Google; run `gemini` login)
# Optional adapter overrides:
# CLEARVIEW_CLAUDE_BIN=claude
# CLEARVIEW_CODEX_BIN=codex
# CLEARVIEW_GEMINI_BIN=gemini
# CLEARVIEW_CLI_TIMEOUT_SEC=120

# Ollama (free local models; used by the `local` tier / plan-execute routing)
OLLAMA_BASE_URL=http://localhost:11434
# Health probe: ollama/* models count as available only when the local server
# answers (30s TTL cache), so local-tier routes fall back to cloud tiers
# instead of erroring when ollama is down.
CLEARVIEW_OLLAMA_PROBE=1

# Core paths / bind
CLEARVIEW_POLICY_PATH=./policy.yaml
CLEARVIEW_DB_PATH=./clearview.db
CLEARVIEW_HOST=127.0.0.1
CLEARVIEW_PORT=8000

# ─── Optional features (sensible defaults; uncomment to change) ─────────────

# Baseline for plan-equiv cost / savings (defaults to policy.yaml value)
# CLEARVIEW_BASELINE_MODEL=anthropic/claude-opus-4-8

# Admin auth: unset = open local dev; set to require a bearer on /admin/* and
# /metrics. REQUIRED if you bind to anything other than 127.0.0.1.
# CLEARVIEW_ADMIN_TOKEN=

# Gateway client-key allow-list (comma-separated); unset = any key accepted.
# Covers /v1/* client traffic and /feedback. REQUIRED on non-loopback binds.
# CLEARVIEW_CLIENT_KEYS=

# Add the Secure flag to the /chat session cookie (set when serving over TLS)
# CLEARVIEW_COOKIE_SECURE=1

# Max request body size in bytes (0 = unlimited). Default 10 MiB.
# CLEARVIEW_MAX_BODY_BYTES=10485760

# Force the built-in $0 mock provider for everything (offline demo)
# CLEARVIEW_USE_MOCK=1
# Serve mock instead of 502 when an upstream fails with no escalation target
# CLEARVIEW_MOCK_ON_FAILURE=1

# Prompt caches
# CLEARVIEW_CACHE_ENABLED=1
# CLEARVIEW_CACHE_TTL_SEC=3600
# CLEARVIEW_SEMANTIC_CACHE=1
# CLEARVIEW_SEMANTIC_THRESHOLD=0.95
# CLEARVIEW_EMBEDDING_BACKEND=openai   # openai | local | disabled

# Provider learning — learn which provider wins per prompt type and route
# there. Shadow fires an alternate provider, an LLM judge scores it, routing
# shifts once a bucket has >= MIN_N judged samples.
# CLEARVIEW_PROVIDER_LEARNING=1
# CLEARVIEW_PROVIDER_SHADOW=1
# CLEARVIEW_AUTO_SHADOW_JUDGE=1
# CLEARVIEW_PROVIDER_SHADOW_RATE=1.0   # shadow every request (lower to cap cost)
# CLEARVIEW_PROVIDER_MIN_N=8
# Composite "stock-market" scoring: rank providers by quality+cost+latency+burn
# CLEARVIEW_PROVIDER_SCORING=1
# CLEARVIEW_SCORE_W_QUALITY=0.5
# CLEARVIEW_SCORE_W_COST=0.25
# CLEARVIEW_SCORE_W_LATENCY=0.15
# CLEARVIEW_SCORE_W_BURN=0.10

# Routing quality signals
# CLEARVIEW_AUTO_SHADOW=disagree       # auto-shadow on rule/classifier disagreement
# CLEARVIEW_EMBED_CLASSIFIER=1         # kNN fallback when LLM classifier disabled
